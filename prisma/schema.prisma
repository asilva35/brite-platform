generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OrderStatus {
  QUOTE          // Quote initial
  REMEASURE      // Pending technical measurements by PM
  PROD_REVIEW    // Validation by production team
  READY_FOR_PROD // Approved for production
  IN_PRODUCTION  // In plant
  READY_TO_SHIP  // Logistics
  OUT_FOR_INST   // On the way to installation
  INSTALLED      // Completed
  CANCELLED
}

enum UserRole {
  ADMIN
  SALES_REP
  PM             // Project Manager
  PRODUCTION
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  role      UserRole @default(SALES_REP)
  name      String?
  quotes    Quote[]  // Relationship with quotes created
  createdAt DateTime @default(now())
}

model Quote {
  id              String      @id @default(cuid())
  status          OrderStatus @default(QUOTE)
  customerName    String
  customerAddress String      // For Google Maps integration
  
  // Finanzas
  totalPrice      Decimal     @db.Decimal(12, 2)
  totalCost       Decimal     @db.Decimal(12, 2) // Calculated by BOM Engine
  margin          Decimal     @db.Decimal(5, 2)  // Profit percentage
  
  // Relaciones
  items           LineItem[]
  userId          String
  createdBy       User        @relation(fields: [userId], references: [id])
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model LineItem {
  id            String   @id @default(cuid())
  productName   String   // E.g.: "Window Wall" or "Hybrid Fusion Window"
  
  // Parametric Dimensions
  width         Float    // Inches/cm
  height        Float
  
  // Remeasure Module (Phase 1)
  fieldWidth    Float?   // Final measurement taken by PM
  fieldHeight   Float?
  hasDiscrepancy Boolean @default(false) // Automatic flag if they differ
  
  // Technical Configuration
  options       Json     // { glass: "Trimax", color: "Slate", blinds: true }
  bomData       Json?    // Material breakdown for production - Phase 2
  
  quoteId       String
  quote         Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}